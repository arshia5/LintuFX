# PostgreSQL container values
DB_HOST=db
DB_NAME=fx_ledger
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=change-this-password

# API bind address used by Docker publishing.
API_BIND=127.0.0.1
PORT=8000

# Browser CORS origins for frontend apps.
CORS_ALLOWED_ORIGINS=http://127.0.0.1:5173,http://localhost:5173
CORS_ALLOWED_ORIGIN_REGEX=

# Optional request source IP allowlist. Leave empty to allow all.
ALLOWED_IPS=

# JWT auth. Generate with: openssl rand -hex 32
JWT_SECRET_KEY=change-this-secret-before-production
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
