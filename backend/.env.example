# DataBase (PostgreSQL)
# Optional full SQLAlchemy URL. If set, this takes precedence over DB_*.
DATABASE_URL=

DB_HOST=localhost
DB_NAME=fx_ledger
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=

# Allowed ip's to connect to the API
# Comma-separated. Leave empty to allow all.
ALLOWED_IPS=

# Browser CORS origins for frontend apps.
# CORS uses origins, not bare IPs. Include scheme and port.
# Examples: http://127.0.0.1:5173,http://192.168.1.10:3000,https://app.example.com
CORS_ALLOWED_ORIGINS=

# Optional advanced CORS regex. If this is empty and ALLOWED_IPS has bare IPs,
# the app will allow http/https origins from those hosts on any port.
CORS_ALLOWED_ORIGIN_REGEX=

# JWT auth
# Generate with: openssl rand -hex 32
JWT_SECRET_KEY=change-this-secret-before-production
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
