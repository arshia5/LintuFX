# Address on the Docker VPS where Nginx listens for browser traffic.
# 0.0.0.0 means "listen on every network interface", so the app is reachable through
# the VPS public IP and, if installed, its Tailscale IP. Use 127.0.0.1 only if another
# reverse proxy on the same VPS will sit in front of this compose stack.
WEB_BIND=0.0.0.0

# Public HTTP port exposed by the web container. Keep 80 for normal http:// access.
# Change to 8080 or another port if port 80 is already used on the VPS.
WEB_PORT=80

# PostgreSQL host reachable from the Docker VPS.
# For your setup, use the existing database VPS Tailscale IP, for example 100.64.x.y.
# A Tailscale MagicDNS name can also work if name resolution is configured on the VPS.
DB_HOST=100.x.y.z

# PostgreSQL database name used by this app.
DB_NAME=fx_ledger

# PostgreSQL port. Default PostgreSQL is 5432.
DB_PORT=5432

# PostgreSQL username.
DB_USERNAME=postgres

# PostgreSQL password for DB_USERNAME. Replace this before running compose.
DB_PASSWORD=change-this-password

# Optional full database URL. Leave DATABASE_URL empty if you use DB_HOST/DB_NAME/etc.
# If DATABASE_URL is set, the backend ignores all DB_* values above.
# Useful when your provider gives you one connection string.
# DATABASE_URL=postgresql://postgres:change-this-password@100.x.y.z:5432/fx_ledger
DATABASE_URL=

# Browser origin where users open the frontend.
# This must exactly match the browser URL: scheme + host + optional port.
# Examples:
#   http://203.0.113.10
#   http://100.64.x.y
#   https://fx.example.com
# If WEB_PORT is not 80/443, include it, for example http://203.0.113.10:8080.
CORS_ALLOWED_ORIGINS=http://YOUR_DOCKER_VPS_IP

# Advanced CORS regex. Keep empty unless you intentionally need pattern matching
# for many allowed frontend origins.
CORS_ALLOWED_ORIGIN_REGEX=

# Optional backend request source IP allowlist.
# Keep this empty for the Docker setup unless you know exactly what you are doing:
# Nginx proxies requests to the API, so the backend often sees the Docker network
# address of the web container rather than the real browser IP.
ALLOWED_IPS=

# Secret used to sign login tokens. Must be long, random, and private.
# Generate a production value with:
#   openssl rand -hex 32
# Changing this value logs out existing sessions.
JWT_SECRET_KEY=change-this-secret-before-production

# Login token lifetime in minutes. 60 means users need to log in again after 1 hour.
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
